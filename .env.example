# MongoDB Configuration
MONGODB_URI=mongodb://root:rootpassword@localhost:27017/mydb?authSource=admin
DATABASE_NAME=mydb

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App Configuration
APP_NAME=RBAC System with JWT & MongoDB
APP_VERSION=1.0.0
DEBUG=True
